# nginx-management — narrowly-scoped sudoers drop-in
#
# Grants the application service account the minimum privileges needed to:
#   • validate the Nginx config   (nginx -t)
#   • reload Nginx                (nginx -s reload)
#   • write nginx.conf            (tee <config_path>)
#
# Installed automatically by deploy.sh to /etc/sudoers.d/nginx-management.
# The placeholders below are substituted at install time.
#
#   __APP_USER__        — service account (e.g. www-data)
#   __NGINX_BIN__       — full path to nginx binary (e.g. /usr/sbin/nginx)
#   __NGINX_CONF__      — full path to nginx.conf   (e.g. /etc/nginx/nginx.conf)

__APP_USER__ ALL=(root) NOPASSWD: \
    __NGINX_BIN__ -t, \
    __NGINX_BIN__ -s reload, \
    /usr/bin/tee __NGINX_CONF__, \
    /usr/bin/cp /tmp/*.conf /etc/nginx/sites-available/, \
    /usr/bin/ln -sf /etc/nginx/sites-available/*.conf /etc/nginx/sites-enabled/, \
    /usr/bin/rm -rf /var/www/*, \
    /usr/bin/certbot *, \
    /usr/bin/pm2 *, \
    /usr/bin/tee -a /etc/hosts
