{
  "apps": [
    {
      "name": "{{name}}",
      "script": "{{start_command}}",
      "cwd": "{{project_path}}",
      "env": {
        "PORT": "{{port}}",
        {{environment_vars_json}}
      },
      "instances": "max",
      "exec_mode": "cluster",
      "watch": false,
      "max_memory_restart": "1G"
    }
  ]
}
