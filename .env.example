# Application
APP_ENV=production
APP_HOST=127.0.0.1
APP_PORT=9991

# Nginx
NGINX_CONFIG_PATH=/etc/nginx/nginx.conf
NGINX_PID_PATH=/var/run/nginx.pid
NGINX_BINARY=nginx
# Use sudo for nginx -t, nginx -s reload, and config writes in production.
# Requires the sudoers drop-in installed by deploy.sh (deploy/nginx-management-sudoers).
NGINX_USE_SUDO=true
